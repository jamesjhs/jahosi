# Server
PORT=3000

# Contact form — routing
# Use an unguessable path to reduce spam — replace RANDOM with your own suffix.
CONTACT_PAGE_PATH=/about/contact-RANDOM

# Contact form — email addresses
# Address that receives submitted messages
CONTACT_TO_EMAIL=you@example.com
# Display name and address used as the From header on outgoing mail
CONTACT_FROM_EMAIL=Portfolio Contact <no-reply@example.com>

# Contact form — SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user@example.com
SMTP_PASS=

# Contact form — anti-spam
# Secret used to sign the math-based human check.
# Set to a long random string in production.
MATH_SECRET=

# Splash chemistry chat (optional)
# When unset, /splash/chat is disabled.
SPLASH_OPENAI_API_KEY=
# Optional OpenAI-compatible base URL. Defaults to https://api.openai.com/v1
SPLASH_OPENAI_BASE_URL=
